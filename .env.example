# Copy this file to `.env` (repo root) and fill in. `.env` is gitignored — never commit it.

# Replicate API token — used by the asset-generation scripts in tools/ to
# generate all game art via the Retro Diffusion pixel-art models.
# Get it at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=r8_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cloudflare API token — lets `wrangler deploy` publish to Cloudflare Workers.
# Create at https://dash.cloudflare.com/profile/api-tokens ("Edit Cloudflare Workers" template).
CLOUDFLARE_API_TOKEN=cfut_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
